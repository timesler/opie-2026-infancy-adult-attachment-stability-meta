      numerator <- ad - bc
      denominator <- sqrt((cell_11 + cell_12) * (cell_21 + cell_22) * 
                          (cell_11 + cell_21) * (cell_12 + cell_22))
      ifelse(denominator > 0, numerator / denominator, NA)
